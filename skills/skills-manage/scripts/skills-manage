#!/usr/bin/env python3
"""skills-manage CLI — browse/install/uninstall skills from private GitLab repo"""
import json
import os
import shutil
import sys
import urllib.request
import urllib.error

GH = "http://10.10.11.4:30690"
PE = "product%2Fiot%2Fiottool%2Fskills"
BR = "develop"
SD = os.path.expanduser("~/.hermes/skills")
EP = os.path.expanduser("~/.hermes/.env")


def get_token():
    t = os.environ.get("GITLAB_TOKEN")
    if t:
        return t
    if not os.path.exists(EP):
        return None
    with open(EP) as f:
        for line in f:
            line = line.strip()
            if "=" in line:
                k, v = line.split("=", 1)
                if k.strip() == "GITLAB_TOKEN":
                    return v
    return None


def api_get(path):
    t = get_token()
    if not t:
        print("Error: GITLAB_TOKEN not set")
        print("  add to ~/.hermes/.env or export GITLAB_TOKEN")
        sys.exit(1)
    url = f"{GH}/api/v4/projects/{PE}/{path}"
    req = urllib.request.Request(url)
    req.add_header("PRIVATE-TOKEN", t)
    with urllib.request.urlopen(req, timeout=10) as r:
        return r.read().decode()


def list_skills():
    data = json.loads(api_get(
        f"repository/files/skills-catalog.json/raw?ref={BR}"))
    return data.get("skills", [])


def cmd_browse():
    skills = list_skills()
    print()
    print(f"  Hermes Skills Hub  --  {len(skills)} skills\n")
    print(f"  {'#':<3} {'Name':<20} {'Description'}")
    print(f"  {'-'*3} {'-'*20} {'-'*40}")
    for i, s in enumerate(skills, 1):
        desc = s['description'][:38]
        print(f"  {i:<3} {s['name']:<20} {desc}")
    print()
    print("  Install:")
    for s in skills:
        print(f"    skills-manage install {s['name']}")
    print()


def cmd_install(name):
    skills = list_skills()
    found = [s for s in skills if s["name"] == name]
    if not found:
        print(f"Not found: {name}")
        return
    target = os.path.join(SD, name)
    os.makedirs(target, exist_ok=True)
    path = f"repository/files/skills%2F{name}%2FSKILL.md/raw?ref={BR}"
    content = api_get(path)
    with open(os.path.join(target, "SKILL.md"), "w") as f:
        f.write(content)
    print(f"OK {name}")


def cmd_uninstall(name):
    # 搜索技能目录（可能在子目录下）
    target = None
    for root, dirs, files in os.walk(SD):
        if os.path.basename(root) == name and "SKILL.md" in files:
            target = root
            break
    if not target:
        print(f"Not installed: {name}")
        return
    shutil.rmtree(target)
    print(f"Removed {name}")


def print_help():
    print("Usage:")
    print("  skills-manage browse")
    print("  skills-manage install <name>")
    print("  skills-manage uninstall <name>")
    print()
    print("Examples:")
    print("  skills-manage install hello-hermes")


if __name__ == "__main__":
    if len(sys.argv) < 2:
        print_help()
        sys.exit(1)
    cmd = sys.argv[1]
    if cmd in ("-h", "--help", "help"):
        print_help()
    elif cmd == "browse":
        cmd_browse()
    elif cmd == "install":
        if len(sys.argv) < 3:
            print("Usage: skills-manage install <name>")
            sys.exit(1)
        cmd_install(sys.argv[2])
    elif cmd == "uninstall":
        if len(sys.argv) < 3:
            print("Usage: skills-manage uninstall <name>")
            sys.exit(1)
        cmd_uninstall(sys.argv[2])
    else:
        print(f"Unknown: {cmd}")
        print_help()
        sys.exit(1)
